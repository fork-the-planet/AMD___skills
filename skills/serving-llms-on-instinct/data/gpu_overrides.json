      "env_vars": {
        "VLLM_USE_V1": "1",
        "VLLM_ROCM_USE_AITER_MHA": "0",
        "VLLM_V1_USE_PREFILL_DECODE_ATTENTION": "1",
        "VLLM_USE_TRITON_FLASH_ATTN": "0",
